# ──────────────────────────────────────────────────────────────────────────────
# Atrium — environment variables
# Copy this file to .env.local and fill in real values. .env.local is gitignored.
# ──────────────────────────────────────────────────────────────────────────────
#
# T-001 status: Atrium currently needs NO environment variables to run.
# This file is committed as a structural placeholder for env vars that future
# tickets will wire up.
#
# Anthropic auth: Atrium inherits the existing `claude auth` session — there is
# no Anthropic API key in Atrium itself. (Locked Decision §3 in CLAUDE.md)

# ──────────────────────────────────────────────────────────────────────────────
# Future — wired up in later waves. Leave blank for now.
# ──────────────────────────────────────────────────────────────────────────────

# Linear API token — used by the in-app ticket sync (Wave 0.5 / drag-to-reorder).
# Get one at https://linear.app/settings/api
LINEAR_API_KEY=

# GitHub token — used for PR-flavoured artefacts in Wave 4 (audit-trail timeline
# can deep-link to a PR). Optional; the app falls back to read-only git state.
GITHUB_TOKEN=

# Path to the Claude CLI binary. Defaults to whichever `claude` is on PATH.
# Override only if you have multiple installs or are testing a beta build.
ATRIUM_CLAUDE_BIN=
