{
  "name": "atrium-cockpit",
  "displayName": "Atrium Cockpit",
  "description": "Linear / PRD / sprint cockpit for Claude Code — live mock-up POC running as a VS Code extension.",
  "version": "0.0.1",
  "publisher": "atrium",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/stonekey908/atrium.git",
    "directory": "extension"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "atrium",
          "title": "Atrium",
          "icon": "media/atrium.svg"
        }
      ]
    },
    "views": {
      "atrium": [
        {
          "id": "atrium.cockpit",
          "name": "Cockpit",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "atrium.openDashboard",
        "title": "Atrium: Open Dashboard (full tab)"
      }
    ]
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json",
    "build:webview": "vite build",
    "build:host": "tsc -p tsconfig.json",
    "watch:webview": "vite build --watch",
    "watch:host": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "vite build && tsc -p tsconfig.json"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/vscode": "^1.98.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5",
    "jsdom": "^26"
  }
}
